# ─────────────────────────────────────────────────────────
# MES API — Variables de entorno
# ─────────────────────────────────────────────────────────

# Azure SQL Database
AZURE_SQL_SERVER=server-mes-jdm-automations.database.windows.net
AZURE_SQL_DATABASE=mes_db
AZURE_SQL_USER=mes_db
AZURE_SQL_PASSWORD=TuPasswordSegura123!

# Servidor
PORT=3000
NODE_ENV=production

# CORS — URL de tu Azure Static Web Apps
CORS_ORIGIN=https://tu-app.azurestaticapps.net

# Azure AD (opcional — para autenticación JWT)
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
